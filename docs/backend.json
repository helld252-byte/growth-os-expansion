{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user within the Growth OS application, including their profile information and assigned role.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "displayName": {
          "type": "string",
          "description": "The name of the user."
        },
        "photoURL": {
          "type": "string",
          "description": "URL to the user's profile picture."
        },
        "role": {
          "type": "string",
          "description": "The role assigned to the user."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "email"
      ]
    },
    "GrowthOpportunity": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "GrowthOpportunity",
      "type": "object",
      "description": "Represents a single growth opportunity, channel, or platform.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "market": { "type": "string" },
        "website": { "type": "string", "format": "uri" },
        "ownerId": { "type": "string" },
        "priority": { "type": "string", "enum": ["High", "Medium", "Low"] },
        "estimatedValue": { "type": "number" },
        "fitScore": { "type": "number" },
        "riskLevel": { "type": "string", "enum": ["High", "Medium", "Low"] },
        "currentStage": { "type": "string" },
        "dateStarted": { "type": "string", "format": "date" },
        "lastUpdate": { "type": "string", "format": "date-time" },
        "productsUploaded": { "type": "boolean" },
        "salesStarted": { "type": "boolean" },
        "nextStep": { "type": "string" },
        "dueDate": { "type": "string", "format": "date" },
        "contactPerson": { "type": "string" },
        "contactEmail": { "type": "string", "format": "email" },
        "notes": { "type": "string" },
        "requirements": {
          "type": "array",
          "items": { "type": "string" }
        },
        "completedRequirements": {
          "type": "array",
          "items": { "type": "string" }
        },
        "journal": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "date": { "type": "string", "format": "date-time" },
              "user": { "type": "string" },
              "content": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": [
        "name",
        "type",
        "ownerId",
        "currentStage"
      ]
    },
    "Partner": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Partner",
      "type": "object",
      "description": "Represents a strategic partner or growth vertical entry (School, Cafe, Community, etc.).",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["School", "Cafe", "Milk Brand", "Co-branding", "Event", "Influencer", "Forum", "Blog", "Review Site"] },
        "status": { "type": "string" },
        "contact": { "type": "string" },
        "impactScore": { "type": "number" },
        "ownerId": { "type": "string" },
        "lastContact": { "type": "string", "format": "date" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "type", "status", "ownerId"]
    },
    "Task": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Task",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "ownerId": { "type": "string" },
        "priority": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string" },
        "growthOpportunityId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "ownerId", "status"]
    },
    "CompanyResource": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "CompanyResource",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "content": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "taxId": { "type": "string" },
        "links": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "url": { "type": "string", "format": "uri" }
            }
          }
        },
        "lastUpdatedByUserId": { "type": "string" },
        "lastUpdatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "category", "content"]
    }
  },
  "auth": {
    "providers": [
      "google.com"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles."
        }
      },
      {
        "path": "/roles_admin/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Admin role markers."
        }
      },
      {
        "path": "/growth_opportunities/{id}",
        "definition": {
          "entityName": "GrowthOpportunity",
          "schema": { "$ref": "#/backend/entities/GrowthOpportunity" },
          "description": "Market expansion platforms."
        }
      },
      {
        "path": "/partners/{id}",
        "definition": {
          "entityName": "Partner",
          "schema": { "$ref": "#/backend/entities/Partner" },
          "description": "Strategic partnerships and specialized verticals."
        }
      },
      {
        "path": "/tasks/{id}",
        "definition": {
          "entityName": "Task",
          "schema": { "$ref": "#/backend/entities/Task" },
          "description": "Operational tasks."
        }
      },
      {
        "path": "/company_resources/{id}",
        "definition": {
          "entityName": "CompanyResource",
          "schema": { "$ref": "#/backend/entities/CompanyResource" },
          "description": "Intelligence Hub assets."
        }
      }
    ]
  }
}
