rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * GROWTH OS SECURITY RULES - v2.6.0
     *
     * Updated to support nested role markers for increased operational flexibility.
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user is an admin, looking in both top-level and nested structures. */
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/users/$(request.auth.uid)/roles_admin/$(request.auth.uid))
      );
    }

    function hasBusinessReadAccess() {
      return isSignedIn();
    }

    function hasBusinessWriteAccess() {
      return isAdmin() || exists(/databases/$(database)/documents/roles_operator/$(request.auth.uid));
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if (isOwner(userId) && request.resource.data.id == userId) || isAdmin();
      allow update: if (isOwner(userId) && request.resource.data.id == resource.data.id) || isAdmin();
      allow delete: if isAdmin();
      
      // Allow the specific nested roles subcollection
      match /roles_admin/{docId} {
        allow read, write: if isAdmin() || isOwner(userId);
      }
    }

    match /roles_admin/{userId} {
      allow read, write: if isAdmin();
    }

    match /growth_opportunities/{opportunityId} {
      allow get, list: if hasBusinessReadAccess();
      allow create: if hasBusinessWriteAccess();
      allow update: if hasBusinessWriteAccess();
      allow delete: if isAdmin();
    }

    match /campaigns/{campaignId} {
      allow get, list: if hasBusinessReadAccess();
      allow create: if hasBusinessWriteAccess();
      allow update: if hasBusinessWriteAccess();
      allow delete: if isAdmin();
    }

    match /partners/{partnerId} {
      allow get, list: if hasBusinessReadAccess();
      allow create: if hasBusinessWriteAccess();
      allow update: if hasBusinessWriteAccess();
      allow delete: if isAdmin();
    }

    match /tasks/{taskId} {
      allow get, list: if hasBusinessReadAccess();
      allow create: if hasBusinessWriteAccess();
      allow update: if hasBusinessWriteAccess();
      allow delete: if isAdmin();
    }

    match /company_resources/{resourceId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}