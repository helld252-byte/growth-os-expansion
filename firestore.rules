rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * GROWTH OS SECURITY RULES
     *
     * Core Philosophy: 
     * This ruleset implements a Role-Based Access Control (RBAC) model using specialized 
     * collections to represent global permissions (Database Access Control - DBAC). This 
     * allows for highly performant security checks without hierarchical data dependencies.
     *
     * Data Structure:
     * - /users/{userId}: User profile data.
     * - /roles_{roleName}/{userId}: Flag collections used to verify global roles (Admin, Manager, Operator, Viewer).
     * - /growth_opportunities: Top-level collection for market platforms and channels.
     * - /campaigns: Marketing initiatives and pushes.
     * - /partners: Strategic partnerships and ecosystem.
     * - /tasks: Top-level collection for operational tasks.
     * - /company_resources: Centralized knowledge hub for all users.
     * - /tags: Global categorization system.
     */

    // --- HELPER FUNCTIONS ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the user's UID matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Verifies a document exists and the user is the owner. Used for updates/deletes. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** @description Checks if the user is registered in the Admin role collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /** @description Checks if the user is registered in the Manager role collection. */
    function isManager() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_manager/$(request.auth.uid));
    }

    /** @description Checks if the user is registered in the Operator role collection. */
    function isOperator() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_operator/$(request.auth.uid));
    }

    /** @description Checks if the user is registered in the Viewer role collection. */
    function isViewer() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_viewer/$(request.auth.uid));
    }

    /** @description Generic check for any role that allows read access to core business data. */
    function hasBusinessReadAccess() {
      return isAdmin() || isManager() || isOperator() || isViewer();
    }

    /** @description Generic check for any role that allows write access to core business data. */
    function hasBusinessWriteAccess() {
      return isAdmin() || isOperator();
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for the User collection. Users manage their own profiles; Admins have full control.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if (isOwner(userId) && request.resource.data.id == userId) || isAdmin();
      allow update: if (isExistingOwner(userId) && request.resource.data.id == resource.data.id) || isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description DBAC Collections for Role Management.
     */
    match /{roleCollection}/{userId} {
      function isRoleCollection() {
        return roleCollection == "roles_admin" || roleCollection == "roles_manager" || roleCollection == "roles_operator" || roleCollection == "roles_viewer";
      }

      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow write: if isAdmin() && isRoleCollection();
    }

    /**
     * @description Operational data for growth opportunities.
     */
    match /growth_opportunities/{opportunityId} {
      allow get, list: if hasBusinessReadAccess();
      allow create: if hasBusinessWriteAccess() && request.resource.data.ownerId == request.auth.uid;
      allow update: if hasBusinessWriteAccess() && resource != null;
      allow delete: if isAdmin() && resource != null;
    }

    /**
     * @description Marketing campaigns and initiatives.
     */
    match /campaigns/{campaignId} {
      allow get, list: if hasBusinessReadAccess();
      allow create: if hasBusinessWriteAccess() && request.resource.data.ownerId == request.auth.uid;
      allow update: if hasBusinessWriteAccess() && resource != null;
      allow delete: if isAdmin() && resource != null;
    }

    /**
     * @description Strategic partnerships and ecosystem contacts.
     */
    match /partners/{partnerId} {
      allow get, list: if hasBusinessReadAccess();
      allow create: if hasBusinessWriteAccess() && request.resource.data.ownerId == request.auth.uid;
      allow update: if hasBusinessWriteAccess() && resource != null;
      allow delete: if isAdmin() && resource != null;
    }

    /**
     * @description Tasks associated with growth opportunities and users.
     */
    match /tasks/{taskId} {
      allow get, list: if hasBusinessReadAccess();
      allow create: if hasBusinessWriteAccess() && request.resource.data.ownerId == request.auth.uid;
      allow update: if hasBusinessWriteAccess() && resource != null && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isAdmin() && resource != null;
    }

    /**
     * @description Reusable company assets and information.
     */
    match /company_resources/{resourceId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin() && request.resource.data.lastUpdatedByUserId == request.auth.uid;
      allow update: if isAdmin() && resource != null;
      allow delete: if isAdmin() && resource != null;
    }

    /**
     * @description Global tagging system for categorization.
     */
    match /tags/{tagId} {
      allow get, list: if isSignedIn();
      allow create, update: if isAdmin();
      allow delete: if isAdmin() && resource != null;
    }
  }
}